rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read for front-office display
    match /carousel-slides/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /service-items/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /sections/{docId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
